            fn unwrap_hidden_rules<'a>(
                node: &'a ::adze::pure_parser::ParsedNode,
            ) -> &'a ::adze::pure_parser::ParsedNode {
                if (node.kind().starts_with('_') || node.children.len() == 1)
                    && node.children.len() > 0
