#!/usr/bin/env bash
# Pre-commit hook for rust-sitter development
# Robust version with partial staging detection, targeted formatting, and full diagnostics
set -euo pipefail

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Set locale to avoid warnings
export LC_ALL=C.UTF-8
export LANG=C.UTF-8

# Check system resource pressure and adjust behavior
check_system_pressure() {
    local max_load_avg=8.0
    local max_memory_percent=85
    local max_processes=500
    
    # Check load average (1-minute)
    if command -v uptime >/dev/null 2>&1; then
        local load_avg
        load_avg=$(uptime | awk -F'load average:' '{print $2}' | awk -F',' '{print $1}' | tr -d ' ')
        if command -v bc >/dev/null 2>&1 && [ -n "$load_avg" ]; then
            if echo "$load_avg > $max_load_avg" | bc -l >/dev/null 2>&1; then
                echo -e "${YELLOW}⚠${NC} High system load ($load_avg), using conservative settings"
                export HOOK_CONSERVATIVE_MODE=1
                return 0
            fi
        fi
    fi
    
    # Check memory usage
    if [ -f /proc/meminfo ]; then
        local mem_total mem_available mem_used_percent
        mem_total=$(awk '/MemTotal:/ {print $2}' /proc/meminfo)
        mem_available=$(awk '/MemAvailable:/ {print $2}' /proc/meminfo)
        if [ -n "$mem_total" ] && [ -n "$mem_available" ]; then
            mem_used_percent=$(( (mem_total - mem_available) * 100 / mem_total ))
            if [ "$mem_used_percent" -gt "$max_memory_percent" ]; then
                echo -e "${YELLOW}⚠${NC} High memory usage (${mem_used_percent}%), using conservative settings"
                export HOOK_CONSERVATIVE_MODE=1
                return 0
            fi
        fi
    fi
    
    # Check running processes
    local process_count
    process_count=$(ps aux | wc -l)
    if [ "$process_count" -gt "$max_processes" ]; then
        echo -e "${YELLOW}⚠${NC} High process count ($process_count), using conservative settings"
        export HOOK_CONSERVATIVE_MODE=1
        return 0
    fi
    
    return 0
}

# Function to run command with timeout and resource monitoring
run_with_timeout() {
    local timeout_duration="$1"
    local description="$2"
    shift 2
    local cmd=("$@")
    
    # Adjust timeout in conservative mode - but cap at reasonable limits
    if [ "${HOOK_CONSERVATIVE_MODE:-0}" = "1" ]; then
        # In conservative mode, extend timeouts but cap at 120s max
        timeout_duration=$((timeout_duration * 2))
        if [ "$timeout_duration" -gt 120 ]; then
            timeout_duration=120
        fi
        echo -e "${BLUE}  →${NC} Running: $description (conservative timeout: ${timeout_duration}s - waiting for system resources)"
        echo -e "${YELLOW}    ⚠${NC} System under load, this may take longer than usual"
    else
        echo -e "${BLUE}  →${NC} Running: $description (timeout: ${timeout_duration}s)"
    fi
    
    if command -v timeout >/dev/null 2>&1; then
        if timeout "$timeout_duration" "${cmd[@]}"; then
            return 0
        else
            local exit_code=$?
            if [ $exit_code -eq 124 ]; then
                echo -e "${RED}✖ $description timed out after ${timeout_duration}s${NC}"
                echo "Current system status:"
                uptime 2>/dev/null || true
                echo "Running Cargo processes: $(pgrep -c cargo 2>/dev/null || echo 0)"
                
                # In conservative mode, offer to wait for resources
                if [ "${HOOK_CONSERVATIVE_MODE:-0}" = "1" ]; then
                    echo ""
                    echo -e "${YELLOW}Options:${NC}"
                    echo "  1. Wait 30s for system load to decrease and retry"
                    echo "  2. Continue with manual verification required"
                    echo "  3. Abort commit"
                    read -p "Choose (1/2/3): " -t 10 choice || choice="2"
                    
                    case "$choice" in
                        1)
                            echo "Waiting 30s for system resources..."
                            sleep 30
                            echo "Retrying $description..."
                            return 125  # Special code for retry
                            ;;
                        2)
                            echo -e "${YELLOW}⚠ Manual verification required after commit${NC}"
                            echo "Run: ${cmd[*]}"
                            return 0  # Allow commit but warn
                            ;;
                        *)
                            echo "Aborting commit"
                            return 1
                            ;;
                    esac
                else
                    echo "Consider reducing scope or investigating system resource contention"
                fi
            fi
            return $exit_code
        fi
    else
        # Fallback without timeout if timeout command not available
        echo -e "${YELLOW}⚠${NC} timeout command not available, running without timeout"
        "${cmd[@]}"
    fi
}

# Function to check if a package has tree-sitter-c2rust feature
has_c2rust_feature() {
    local pkg="$1"
    
    if ! command -v jq >/dev/null 2>&1; then
        return 1  # jq not available, skip feature check
    fi
    
    local c2rust_packages
    # Use offline flag and timeout to prevent hanging
    c2rust_packages=$(run_with_timeout 30 "cargo metadata for feature check" \
        cargo metadata --format-version 1 --offline 2>/dev/null | \
        jq -r '.packages[] | select(.features["tree-sitter-c2rust"] != null) | .name' 2>/dev/null || true)
    
    if [ -z "$c2rust_packages" ]; then
        return 1  # No packages found
    fi
    
    echo "$c2rust_packages" | grep -q "^${pkg}$"
}

# Add iteration tracking for better UX
HOOK_ITERATION=${HOOK_ITERATION:-0}
export HOOK_ITERATION=$((HOOK_ITERATION + 1))

if [ "$HOOK_ITERATION" -gt 1 ]; then
    echo -e "${GREEN}[pre-commit]${NC} Stabilizing formatting (iteration $HOOK_ITERATION)..."
else
    echo -e "${GREEN}[pre-commit]${NC} Running formatting and validation checks..."
fi
echo -e "${BLUE}→${NC} Using robust pre-commit hook from .githooks/"

# Check system pressure before starting heavy operations
check_system_pressure

# Safety guard against infinite loops
if [ "$HOOK_ITERATION" -gt 5 ]; then
    echo -e "${RED}✖ Too many formatting iterations. Check for conflicting formatting rules.${NC}"
    exit 1
fi

# Step 0: Fast fail if conflict markers are present
# Look for actual git conflict markers (7 characters for <<<<<<< and >>>>>>> exactly)
if command -v rg >/dev/null 2>&1; then
    if rg -n --hidden --glob '!.git' --glob '!*.txt' --glob '!*.md' --glob '!*.sh' '^(<<<<<<<\s|=======$|>>>>>>>\s)' . >/dev/null 2>&1; then
        echo -e "${RED}✖ Merge conflict markers found. Please resolve them before committing.${NC}"
        rg -n --hidden --glob '!.git' --glob '!*.txt' --glob '!*.md' --glob '!*.sh' '^(<<<<<<<\s|=======$|>>>>>>>\s)' . || true
        exit 1
    fi
fi

# Function to check if a file is partially staged
check_partial_staging() {
    local file="$1"
    
    # Get the staged content hash and working directory content hash
    staged_hash=$(git hash-object --stdin < <(git show ":$file" 2>/dev/null || echo ""))
    working_hash=$(git hash-object "$file" 2>/dev/null || echo "")
    
    # If hashes differ and file is staged, it's partially staged
    if [ "$staged_hash" != "$working_hash" ] && git diff --cached --name-only | grep -q "^$file$"; then
        return 0  # Is partially staged
    fi
    return 1  # Not partially staged
}

# Step 1: Detect partially staged Rust files (exclude deletions and non-Rust files)
echo -e "${YELLOW}→${NC} Checking for partially staged files..."

# Collect staged & unstaged Rust files (exclude deletions with --diff-filter)
mapfile -t staged_rs < <(git diff --name-only --cached --diff-filter=ACMRT -- '*.rs' 2>/dev/null || true)
mapfile -t unstaged_rs < <(git diff --name-only --diff-filter=ACMRT -- '*.rs' 2>/dev/null || true)

if ((${#staged_rs[@]})) && ((${#unstaged_rs[@]})); then
    # Find intersection
    declare -A set=()
    for f in "${unstaged_rs[@]}"; do set["$f"]=1; done
    partial=()
    for f in "${staged_rs[@]}"; do
        [[ -n "${set[$f]:-}" ]] && partial+=("$f")
    done
    if ((${#partial[@]})); then
        echo -e "${RED}✖ Partially-staged Rust files detected${NC}"
        echo "The following Rust files have both staged and unstaged changes:"
        printf "  • %s\n" "${partial[@]}"
        echo ""
        echo "This can lead to formatting issues where staged content differs from working content."
        echo "Please either:"
        echo "  1. Stage all changes: git add <file>"
        echo "  2. Unstage partial changes: git reset <file>"
        echo "  3. Stash unstaged changes: git stash --keep-index"
        echo ""
        exit 1
    fi
fi
echo -e "${GREEN}✓${NC} No partially staged files found"

# Step 2: Get list of staged Rust files for targeted formatting
echo -e "${YELLOW}→${NC} Identifying staged Rust files..."
STAGED_RUST_FILES=()
while IFS= read -r -d '' file; do
    if [[ "$file" == *.rs ]]; then
        STAGED_RUST_FILES+=("$file")
    fi
done < <(git diff --cached --name-only -z 2>/dev/null || true)

if [ ${#STAGED_RUST_FILES[@]} -eq 0 ]; then
    echo -e "${BLUE}→${NC} No staged Rust files found, skipping formatting"
else
    echo -e "${BLUE}→${NC} Found ${#STAGED_RUST_FILES[@]} staged Rust files"
    
    # Step 3: Format only staged Rust files
    echo -e "${YELLOW}→${NC} Formatting staged Rust files..."
    
    # Format the specific files (batch processing for speed)
    if [ ${#STAGED_RUST_FILES[@]} -gt 0 ]; then
        echo -e "${BLUE}  →${NC} Formatting ${#STAGED_RUST_FILES[@]} files in batch"
        # Use rustfmt in batch mode - much faster than per-file processing
        run_with_timeout 30 "rustfmt (batch)" rustfmt "${STAGED_RUST_FILES[@]}" || {
            echo -e "${RED}✖ Failed to format staged files${NC}"
            exit 1
        }
        
        # Check if formatting made any changes to staged files
        FORMATTING_CHANGES=false
        for file in "${STAGED_RUST_FILES[@]}"; do
            if [ -f "$file" ] && ! git diff --quiet "$file"; then
                FORMATTING_CHANGES=true
                echo -e "${BLUE}  →${NC} Staging formatting changes for $file"
                git add "$file"
            fi
        done
        
        if [ "$FORMATTING_CHANGES" = true ]; then
            echo -e "${GREEN}✓${NC} Formatting changes staged"
        else
            echo -e "${GREEN}✓${NC} No formatting changes needed"
        fi
    fi
fi

# Step 4: Run clippy (crate-aware for speed, feature-matrix safe)
echo -e "${YELLOW}→${NC} Clippy (affected crates, feature-safe)..."

# Build package arguments if we have affected crates
pkg_args=()
if command -v jq >/dev/null 2>&1 && [ -f scripts/affected-crates.sh ]; then
    pkgs=()
    while IFS= read -r pkg; do
        pkgs+=("$pkg")
    done < <(scripts/affected-crates.sh || true)
    if [ "${#pkgs[@]}" -gt 0 ]; then
        # Deduplicate & sort for stable output
        sorted_pkgs=()
        while IFS= read -r pkg; do
            sorted_pkgs+=("$pkg")
        done < <(printf "%s\n" "${pkgs[@]}" | sort -u)
        pkgs=("${sorted_pkgs[@]}")
        for p in "${pkgs[@]}"; do pkg_args+=("-p" "$p"); done
        echo "   packages: ${pkgs[*]}"
    else
        echo "   no staged .rs files mapped to crates; using workspace"
    fi
else
    echo "   jq not found or affected-crates.sh missing; using workspace"
fi

# Function to run clippy with specific feature set
run_clippy_set() {
    local mode="$1"   # "default" or feature string
    if [ "$mode" = "default" ]; then
        # Split rust-sitter from other crates: use --lib for rust-sitter
        # (test files have known API drift, tracked in KNOWN_RED.md)
        # and --all-targets for all other crates (matching ci-supported lane).
        local rs_args=() other_args=()
        local i=0
        while [ $i -lt ${#pkg_args[@]} ]; do
            if [ "${pkg_args[$i]}" = "-p" ] && [ $((i + 1)) -lt ${#pkg_args[@]} ]; then
                if [ "${pkg_args[$((i + 1))]}" = "rust-sitter" ]; then
                    rs_args+=("-p" "rust-sitter")
                else
                    other_args+=("${pkg_args[$i]}" "${pkg_args[$((i + 1))]}")
                fi
                i=$((i + 2))
            else
                other_args+=("${pkg_args[$i]}")
                i=$((i + 1))
            fi
        done

        # Run --lib only for rust-sitter (test files have KNOWN_RED API drift)
        if [ ${#rs_args[@]} -gt 0 ]; then
            if ! run_with_timeout 300 "clippy rust-sitter --lib" \
                 cargo clippy -q --lib --no-deps --offline "${rs_args[@]}" -- -D warnings; then
                return 1
            fi
        fi

        # Run --all-targets for all other crates
        if [ ${#other_args[@]} -gt 0 ]; then
            if ! run_with_timeout 300 "clippy (default features)" \
                 cargo clippy -q --all-targets --no-deps --offline "${other_args[@]}" -- -D warnings; then
                return 1
            fi
        fi
    else
        # For feature-specific checks, filter to only packages that support the feature
        if [ "$mode" = "tree-sitter-c2rust" ] && [ "${#pkg_args[@]}" -gt 0 ]; then
            # Filter pkg_args to only include packages that have the feature
            local filtered_args=()
            local i=0
            while [ $i -lt ${#pkg_args[@]} ]; do
                if [ "${pkg_args[$i]}" = "-p" ] && [ $((i + 1)) -lt ${#pkg_args[@]} ]; then
                    pkg="${pkg_args[$((i + 1))]}"
                    if has_c2rust_feature "$pkg"; then
                        filtered_args+=("${pkg_args[$i]}" "${pkg_args[$((i + 1))]}")
                    fi
                    i=$((i + 2))
                else
                    filtered_args+=("${pkg_args[$i]}")
                    i=$((i + 1))
                fi
            done
            
            if [ ${#filtered_args[@]} -eq 0 ]; then
                echo "   no affected packages support $mode feature, skipping"
                return 0
            fi
            
            if ! run_with_timeout 300 "clippy ($mode features)" \
                 cargo clippy -q --all-targets --no-default-features \
                 --features "$mode" --no-deps --offline "${filtered_args[@]}" -- -D warnings; then
                return 1
            fi
        else
            if ! run_with_timeout 300 "clippy ($mode features)" \
                 cargo clippy -q --all-targets --no-default-features \
                 --features "$mode" --no-deps --offline ${pkg_args[@]+"${pkg_args[@]}"} -- -D warnings; then
                return 1
            fi
        fi
    fi
    return 0
}

# Check if we have any affected crates to lint
if [ ${#pkg_args[@]} -eq 0 ]; then
    echo "   no affected crates; skipping clippy in pre-commit"
else
    # Always run baseline (default features)
    if [ "${HOOK_CONSERVATIVE_MODE:-0}" = "1" ]; then
        echo "   clippy: default features (conservative mode - extended timeouts)"
    else
        echo "   clippy: default features"
    fi
    
    # Run clippy with retry logic in conservative mode
    clippy_attempts=0
    max_attempts=2
    while [ $clippy_attempts -lt $max_attempts ]; do
        clippy_attempts=$((clippy_attempts + 1))
        
        if [ $clippy_attempts -gt 1 ]; then
            echo "   clippy attempt $clippy_attempts/$max_attempts"
        fi
        
        run_clippy_set "default"
        clippy_result=$?
        
        if [ $clippy_result -eq 0 ]; then
            break  # Success
        elif [ $clippy_result -eq 125 ] && [ $clippy_attempts -lt $max_attempts ]; then
            echo "   retrying clippy after resource wait..."
            continue  # Retry requested
        else
            echo -e "${RED}✖ Clippy (default) failed${NC}"
            echo ""
            echo "To see detailed clippy output, run:"
            echo "  cargo clippy --all-targets ${pkg_args[*]}"
            echo ""
            exit 1
        fi
    done
fi

# Optional extended feature set at commit time (keeps commit fast by default)
if [ "${RUN_EXTENDED:-0}" = "1" ] && [ ${#pkg_args[@]} -gt 0 ]; then
    echo "   clippy: tree-sitter-c2rust (no-default-features)"
    if ! run_clippy_set "tree-sitter-c2rust"; then
        echo -e "${RED}✖ Clippy (tree-sitter-c2rust) failed${NC}"
        echo ""
        echo "To see detailed clippy output, run:"
        echo "  cargo clippy --all-targets --no-default-features --features tree-sitter-c2rust ${pkg_args[*]}"
        echo ""
        exit 1
    fi
fi
if [ ${#pkg_args[@]} -gt 0 ]; then
    echo -e "${GREEN}✓${NC} Clippy checks passed"
fi

# Step 5: Run GOTO indexing check with full diagnostics
if [ -f scripts/check-goto-indexing.sh ]; then
    echo -e "${YELLOW}→${NC} Checking GOTO indexing patterns..."
    if ! scripts/check-goto-indexing.sh; then
        echo -e "${RED}✖ GOTO indexing check failed${NC}"
        echo ""
        echo "Direct enum flips detected. Use remap helpers instead."
        echo ""
        exit 1
    fi
    echo -e "${GREEN}✓${NC} GOTO indexing patterns verified"
fi

# Step 6: Check for SymbolId(0) misuse in tests (EOF is reserved)
echo -e "${YELLOW}→${NC} Checking for SymbolId(0) misuse..."
if rg -q 'SymbolId\(0\)' runtime/tests glr-core/tests 2>/dev/null | \
   rg -v 'eof_symbol|normalize_eof_to_zero|table\.eof_symbol|SymbolAllocator' >/dev/null 2>&1; then
    echo -e "${YELLOW}⚠${NC} Warning: SymbolId(0) used in tests (reserved for EOF)"
    echo "Consider using SymbolAllocator which starts at 1"
    echo "Problematic usage:"
    rg 'SymbolId\(0\)' runtime/tests glr-core/tests 2>/dev/null | \
       rg -v 'eof_symbol|normalize_eof_to_zero|table\.eof_symbol|SymbolAllocator' | head -3
fi

# Step 7: Run test connectivity check with full output
echo -e "${YELLOW}→${NC} Checking test connectivity..."
if [ -f scripts/check-test-connectivity.sh ]; then
    if ! scripts/check-test-connectivity.sh; then
        echo -e "${RED}✖ Test connectivity check failed${NC}"
        echo ""
        exit 1
    fi
else
    # Inline basic connectivity check if script is missing
    DISABLED_FILES=$(find . -name "*.rs.disabled" -type f 2>/dev/null | grep -v target/ | head -5 || true)
    if [ -n "$DISABLED_FILES" ]; then
        echo -e "${RED}✖ Disabled test files detected:${NC}"
        echo "$DISABLED_FILES" | sed 's/^/  /'
        echo ""
        echo "Disabled test files are not allowed. Either:"
        echo "  1. Re-enable by removing .disabled suffix and fixing issues"
        echo "  2. Use #[ignore] attribute if tests need to remain disabled temporarily"
        echo "  3. Remove files if they are no longer relevant"
        echo ""
        exit 1
    fi
fi
echo -e "${GREEN}✓${NC} Test connectivity verified"

# Step 8: Quick test of critical invariants (optional, crate-aware)
if [ "${RUN_QUICK_TESTS:-0}" = "1" ]; then
    echo -e "${YELLOW}→${NC} Quick tests (affected crates)..."
    if command -v jq >/dev/null 2>&1 && [ -f scripts/affected-crates.sh ]; then
        while IFS= read -r pkg; do
            pkgs+=("$pkg")
        done < <(scripts/affected-crates.sh || true)
    else
        pkgs=()
    fi

    if [ "${#pkgs[@]}" -gt 0 ]; then
        for p in "${pkgs[@]}"; do
            echo "   cargo test -q -p $p --lib"
            cargo test -q -p "$p" --lib || true
        done
    else
        # Fallback to highest-signal tests if we can't resolve packages
        echo "   Running core invariant tests..."
        cargo test -q -p rust-sitter-glr-core --lib -- tests::test_eof_normalization || true
        cargo test -q -p rust-sitter-glr-core --lib -- tests::test_goto_remap || true
    fi
fi

echo ""
echo -e "${GREEN}✅ All pre-commit checks passed${NC}"
echo -e "${BLUE}→${NC} Commit proceeding with staged changes"
exit 0