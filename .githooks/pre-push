#!/usr/bin/env bash
# Pre-push hook for rust-sitter development
# Runs comprehensive checks before pushing to remote
set -euo pipefail

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Set locale to avoid warnings
export LC_ALL=C.UTF-8
export LANG=C.UTF-8

echo -e "${GREEN}[pre-push]${NC} Running comprehensive checks before push..."
echo -e "${BLUE}→${NC} Using robust pre-push hook from .githooks/"

# Read the push details (remote and URL are passed as arguments)
remote="${1:-origin}"
url="${2:-}"

if [ -n "$url" ]; then
    echo -e "${BLUE}→${NC} Pushing to: $remote ($url)"
else
    echo -e "${BLUE}→${NC} Running pre-push checks..."
fi

# Check if there are any commits to push
if ! git log --oneline "@{u}.." >/dev/null 2>&1; then
    echo -e "${YELLOW}⚠${NC} No upstream branch found, skipping push validation"
    exit 0
fi

COMMITS_TO_PUSH=$(git rev-list --count "@{u}.." 2>/dev/null || echo "0")
if [ "$COMMITS_TO_PUSH" -eq 0 ]; then
    echo -e "${BLUE}→${NC} No new commits to push"
    exit 0
fi

echo -e "${BLUE}→${NC} Found $COMMITS_TO_PUSH commit(s) to push"

# Step 1: Check for disabled test files in the commits being pushed
echo -e "${YELLOW}→${NC} Checking commits for disabled test files..."
if git log --name-only --pretty=format: "@{u}.." | grep -q '\.rs\.disabled$'; then
    echo -e "${RED}✖ Disabled test files found in commits being pushed${NC}"
    echo ""
    echo "The following disabled test files are included in your push:"
    git log --name-only --pretty=format: "@{u}.." | grep '\.rs\.disabled$' | sort -u | sed 's/^/  /'
    echo ""
    echo "Please either:"
    echo "  1. Re-enable these files by removing the .disabled suffix"
    echo "  2. Use #[ignore] attribute instead of file renaming"
    echo "  3. Remove the files if they are no longer needed"
    echo ""
    exit 1
fi
echo -e "${GREEN}✓${NC} No disabled test files in push"

# Step 2: Run full formatting check
echo -e "${YELLOW}→${NC} Verifying code formatting..."
if ! cargo fmt --all -- --check; then
    echo -e "${RED}✖ Code formatting issues detected${NC}"
    echo ""
    echo "Please run 'cargo fmt --all' to fix formatting before pushing"
    echo ""
    exit 1
fi
echo -e "${GREEN}✓${NC} Code formatting verified"

# Step 3: Run comprehensive clippy check (per-package with --no-deps)
echo -e "${YELLOW}→${NC} Running comprehensive clippy analysis (per-package, feature matrix)..."

# Compose quarantine from env and file
Q="${CLIPPY_EXCLUDE:-}"
if [ -f .clippy-quarantine ]; then
    # Skip comment lines and empty lines
    F=$(grep -v '^#' .clippy-quarantine 2>/dev/null | grep -v '^[[:space:]]*$' | tr '\n' ',' | sed 's/,$//')
    Q="${Q:+$Q,}${F}"
fi
[ -n "$Q" ] && echo "   (quarantined: $Q)"

# Build quarantine lookup function
IFS=',' read -ra QARR <<< "${Q}"
is_quarantined() {
    local target="$1"
    for x in "${QARR[@]}"; do
        [ -n "$x" ] && [ "$x" = "$target" ] && return 0
    done
    return 1
}

# Get workspace package names
mapfile -t PKGS < <(cargo metadata --format-version 1 2>/dev/null \
    | jq -r '.workspace_members[] | split("#")[1] | split("@")[0]')

if [ ${#PKGS[@]} -eq 0 ]; then
    echo -e "${RED}✖ Failed to get workspace packages${NC}"
    exit 1
fi

fail_clippy() {
    echo -e "${RED}✖ Clippy failed for package: $1 (${2})${NC}"
    echo ""
    echo "Please fix clippy warnings before pushing"
    echo "To reproduce:"
    echo "  $3"
    echo ""
    exit 1
}

# Check each non-quarantined package with --no-deps
echo "   Checking ${#PKGS[@]} workspace packages..."
for p in "${PKGS[@]}"; do
    if is_quarantined "$p"; then
        echo "   clippy: skip (quarantined) $p"
        continue
    fi

    # Check with default features
    echo "   clippy: default features  → $p"
    cmd="cargo clippy -q -p \"$p\" --all-targets --no-deps -- -D warnings"
    if ! eval "$cmd" 2>&1 | head -20; then
        fail_clippy "$p" "default features" "$cmd"
    fi

    # Check with tree-sitter-c2rust feature
    echo "   clippy: tree-sitter-c2rust → $p"
    cmd="cargo clippy -q -p \"$p\" --all-targets --no-default-features --features tree-sitter-c2rust --no-deps -- -D warnings"
    if ! eval "$cmd" 2>&1 | head -20; then
        fail_clippy "$p" "tree-sitter-c2rust" "$cmd"
    fi
done

echo -e "${GREEN}✓${NC} Clippy analysis passed (all non-quarantined packages)"

# Step 4: Run GOTO indexing check with full diagnostics
if [ -f scripts/check-goto-indexing.sh ]; then
    echo -e "${YELLOW}→${NC} Checking GOTO indexing patterns..."
    if ! scripts/check-goto-indexing.sh; then
        echo -e "${RED}✖ GOTO indexing check failed${NC}"
        exit 1
    fi
    echo -e "${GREEN}✓${NC} GOTO indexing patterns verified"
fi

# Step 5: Run test connectivity check
if [ -f scripts/check-test-connectivity.sh ]; then
    echo -e "${YELLOW}→${NC} Verifying test connectivity..."
    if ! scripts/check-test-connectivity.sh; then
        echo -e "${RED}✖ Test connectivity check failed${NC}"
        exit 1
    fi
    echo -e "${GREEN}✓${NC} Test connectivity verified"
fi

# Step 6: Run core tests to ensure basic functionality
echo -e "${YELLOW}→${NC} Running core test suite..."
if ! cargo test -p rust-sitter-glr-core -p rust-sitter-ir -p rust-sitter-tablegen --lib; then
    echo -e "${RED}✖ Core tests failed${NC}"
    echo ""
    echo "Please ensure all tests pass before pushing"
    echo ""
    exit 1
fi
echo -e "${GREEN}✓${NC} Core tests passed"

# Step 7: Optional comprehensive test run (can be enabled with environment variable)
if [ "${RUN_FULL_TESTS:-0}" = "1" ]; then
    echo -e "${YELLOW}→${NC} Running full test suite (RUN_FULL_TESTS=1)..."
    if ! cargo test --workspace; then
        echo -e "${RED}✖ Full test suite failed${NC}"
        echo ""
        echo "Full tests are required for this push"
        echo ""
        exit 1
    fi
    echo -e "${GREEN}✓${NC} Full test suite passed"
fi

# Step 8: Check for breaking changes in public API (if applicable)
if [ -f scripts/check-breaking-changes.sh ]; then
    echo -e "${YELLOW}→${NC} Checking for breaking changes..."
    if ! scripts/check-breaking-changes.sh; then
        echo -e "${YELLOW}⚠${NC} Breaking changes detected (continuing)"
        echo "Review breaking changes carefully before pushing to main"
    else
        echo -e "${GREEN}✓${NC} No breaking changes detected"
    fi
fi

# Step 9: Validate commit messages for the commits being pushed
echo -e "${YELLOW}→${NC} Validating commit messages..."
INVALID_COMMITS=0
while IFS= read -r commit; do
    # Get the commit message (first line only)
    msg=$(git log --format=%s -n 1 "$commit")
    
    # Basic validation: should not be empty, should not be too long
    if [ -z "$msg" ]; then
        echo -e "${RED}✖ Empty commit message in $commit${NC}"
        INVALID_COMMITS=$((INVALID_COMMITS + 1))
    elif [ ${#msg} -gt 72 ]; then
        echo -e "${YELLOW}⚠${NC} Long commit message in $commit (${#msg} chars): ${msg:0:50}..."
    fi
    
    # Check for common patterns that might indicate issues
    if [[ "$msg" =~ ^(WIP|FIXME|TODO|DEBUG) ]]; then
        echo -e "${YELLOW}⚠${NC} Development commit message in $commit: $msg"
    fi
done < <(git rev-list "@{u}..")

if [ $INVALID_COMMITS -gt 0 ]; then
    echo -e "${RED}✖ Found $INVALID_COMMITS invalid commit message(s)${NC}"
    echo "Please fix commit messages before pushing"
    exit 1
fi
echo -e "${GREEN}✓${NC} Commit messages validated"

echo ""
echo -e "${GREEN}✅ All pre-push checks passed${NC}"
echo -e "${BLUE}→${NC} Push proceeding to $remote"
exit 0