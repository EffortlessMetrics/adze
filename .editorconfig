# .editorconfig
# Ensures consistent formatting across different editors and IDEs
root = true

[*]
end_of_line = lf
insert_final_newline = true
charset = utf-8
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.rs]
indent_size = 4

[*.toml]
indent_size = 2

[*.{yml,yaml}]
indent_size = 2

[*.md]
# Preserve trailing spaces in markdown (for line breaks)
trim_trailing_whitespace = false

[Makefile]
indent_style = tab